{
  "name": "ai-music-tagger",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered music metadata tagger",
  "main": "src/client/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "ts-node src/index.ts",
    "update-metadata": "ts-node src/index.ts --update-metadata",
    "merge-analysis-results": "ts-node src/merge-analysis-results.ts",
    "test": "jest",
    "lint": "eslint src/",
    "watch": "tsc -w"
  },
  "keywords": [
    "ai",
    "music",
    "metadata",
    "tagging"
  ],
  "author": "Steppschuh",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/vertexai": "^0.1.0",
    "busboy": "^1.6.0",
    "node-id3": "^0.2.6",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/form-data": "^2.2.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.15.17",
    "@types/node-fetch": "^2.6.12",
    "eslint": "^8.0.0",
    "form-data": "^4.0.2",
    "jest": "^29.0.0",
    "node-fetch": "^2.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
