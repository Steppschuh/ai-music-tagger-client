# macOS Code Signing & Notarization Credentials
# Copy this to '.env' and fill in your actual developer credentials.

# The exact Signing Identity from: security find-identity -p codesigning -v
# Example: "Developer ID Application: Your Name (TEAMID)"
APPLE_SIGNING_IDENTITY=""

# Your Apple ID email address
# Example: "developer@example.com"
APPLE_ID=""

# App-specific password generated at appleid.apple.com (NOT your main password!)
# Example: "abcd-efgh-ijkl-mnop"
APPLE_PASSWORD=""

# Your 10-character Apple Developer Team ID
# Example: "A1B2C3D4E5"
APPLE_TEAM_ID=""
