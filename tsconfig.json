{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["src/renderer/*"]
    }
  },
  "include": ["src/**/*", "forge.config.ts", "*.config.ts"],
  "exclude": ["node_modules", "src/renderer"],
  "references": [{ "path": "./tsconfig.renderer.json" }]
}
